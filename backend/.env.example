# ─── TicketFlow AI — Backend Environment Variables ────────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── Application ──────────────────────────────────────────────────────
APP_NAME=TicketFlow AI
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Security ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MongoDB ───────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=ticketflow_ai

# ── Redis (local) ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Upstash Redis (NLP preprocessing cache) ───────────────────────────
# Get these from https://console.upstash.com → your Redis database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── ChromaDB ──────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── LLM Provider ─────────────────────────────────────────────────────
# "ollama" for local development, "qwen" for production
LLM_PROVIDER=ollama

# ── Ollama (local dev) ────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral-nemo

# ── Qwen (production) ─────────────────────────────────────────────────
# Set LLM_PROVIDER=qwen and fill in your API key for production use.
# NEVER commit a real API key to version control.
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── ML Models ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment

# ── Thresholds ────────────────────────────────────────────────────────
CONFIDENCE_HIGH_THRESHOLD=0.85
CONFIDENCE_LOW_THRESHOLD=0.60
SLA_BREACH_THRESHOLD=0.75
HALLUCINATION_SIM_THRESHOLD=0.3
DUPLICATE_EXACT_THRESHOLD=0.95
DUPLICATE_POSSIBLE_THRESHOLD=0.85
FEEDBACK_RETRAIN_THRESHOLD=50
SENTIMENT_NEGATIVE_THRESHOLD=0.85
